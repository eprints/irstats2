#!/usr/bin/perl -w 

use strict;

# The script should be installed in $EPRINTS_PATH/ingredients/irstats2/bin/stats/
use FindBin;
use lib "$FindBin::Bin/../../../../perl_lib";

use Getopt::Long;
use Pod::Usage;

use EPrints;

my $do_sets = 0;
my $setup = 0;
my $uninstall=0;
our $verbose=0;
my $datasets='';
my $processors='';
my $from_date;

Getopt::Long::Configure("permute");

GetOptions(
	'setup' => \$setup,
	'uninstall' => \$uninstall,
	'verbose' => \$verbose,
	'sets-only' => \$do_sets,
	'datasets=s' => \$datasets,
	'processors=s' => \$processors,
	'from-date=s' => \$from_date,
) || pod2usage( 2 );

# Set STDOUT to auto flush (without needing a \n)
$|=1;

my $repoid = shift @ARGV;
unless( defined $repoid )
{
	&usage();
	exit;
}

my $session = new EPrints::Session( 1, $repoid );
unless( defined $session )
{
	&usage;
	exit;
}

my $handler = $session->plugin( "Stats::Handler", noise => $verbose );
unless($handler)
{
	print STDERR "FATAL ERROR: Stats handler (Stats::Handler.pm) not available\n";
	$session->terminate();
	exit;
}

if( $uninstall )
{
	my $ok = EPrints::Utils::get_input( '^(yes|no)$', "Uninstall IRStats2?", "yes" );
	unless( $ok eq "yes" )
	{
		$session->terminate;
		exit;
	}

	$handler->uninstall();
	$session->terminate;
	exit;
}

if ( $from_date )
{
	unless ( $from_date =~ /^([0-9]{4})-([0-9]{2})-([0-9]{2})$/ && $1 > 1900 && $2 >=1 && $2 <= 12 && $3 >= 1 && $3 <= 31 )
	{
		print STDERR "FATAL ERROR: '$from_date' is not a valid date.  --from-date must be of the form YYYY-MM-DD\n";
		$session->terminate;
                exit;
	}
	$handler->log( "Only re-generating existing records for access dataset from $from_date." );
	$from_date =~ s/-//g;
	$datasets = "access";
}
elsif ( $processors )
{
	$handler->log( "WARNING: --processors has no effect when used without --from-date.", 1 );
	$processors = '';
}

if ( $from_date && $setup )
{
	$from_date = undef;
	$processors = '';
	$handler->log( "WARNING: --from-date has no effect when used with --setup.", 1 );
}

if( $do_sets )
{
	$handler->log( "Doing sets tables only" );
}

unless ( $from_date )
{
	$handler->log( "Generating set tables." );
	$handler->sets->populate_tables();
}

if( $do_sets )
{
	$session->terminate;
	exit( 1 );
}

if( $setup )
{
	$handler->log( "Creating internal tables" );
	$handler->create_internal_tables();
}

my %selected_datasets = map { $_ => 1 } split( /,/, $datasets );

my $dataset_ids = $session->config( "irstats2", "datasets" ) || {};

my %selected_processors = map { $_ => 1 } split( /,/, $processors );

foreach my $dataset_id ( keys %$dataset_ids )
{
	next if( EPrints::Utils::is_set( %selected_datasets ) && !$selected_datasets{$dataset_id} );
	my $conf = $dataset_ids->{$dataset_id};
	next unless( defined $conf );

	$conf->{datasetid} = $dataset_id;
	$conf->{create_tables} = $setup;
	$conf->{from_date} = $from_date if $from_date;
	$conf->{processors} = \%selected_processors if $processors;

	$handler->process_dataset( $dataset_id, $conf );
}

$handler->log( "Leaving now" );


$handler->log( "Clearing cache" );
my $cache_dir = $session->config( 'irstats2', 'cache_dir' );
`find $cache_dir/ -maxdepth 1 -type f -name '*.ir2' -delete`; # Use find rather than rm in case there are a lot of files

my $cache_paths = $session->config( 'irstats2', 'cache_paths' );
if ( defined $cache_paths )
{
	$handler->log( "Requesting stats pages to be cached" );
	for my $cache_path ( @$cache_paths )
	{
		my $full_cache_path = $session->config("rel_cgipath") . $cache_path;
		$handler->log( "Caching $full_cache_path" );
		EPrints::Plugin::Stats::Utils::cache_report( $session, $handler, $full_cache_path );

	}
}

$session->terminate;
exit;

sub usage
{
	print <<USAGE;

$0 ARCHIVE_ID [--setup] [--datasets=DATASETS] [--processors=PROCESSORS] [--sets-only] [--from-date=YYYY-MM-DD] [--uninstall] [--verbose]

\t--setup: use this option the first time to run IRStats2, or if you want to re-process all the statistics.
\t--datasets=<dataset1,[dataset2...]>: this will only generate data for the selected datasets.
\t--sets-only: only re-generates the Set tables. Useful if you've changed the Sets configuration.
\t--from-date: re-generate date-based access stats from a specific date onwards but will not process yet unprocessed records. To save time, will only process access dataset and will not re-generate the Set tables.
\n--processors: restricts which processors are applied, currently only applicable to access dataset specified when used with --from-date, e.g. use to re-generate Country stats for access dataset from a specified date.
\t--uninstall: removes all the data generated by IRStats 2. You will still need to manually remove all the installed files.
\t--verbose: displays extra information (useful for debugging).

USAGE
}
